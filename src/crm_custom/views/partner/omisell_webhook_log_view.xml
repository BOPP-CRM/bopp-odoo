<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_omisell_webhook_log_tree" model="ir.ui.view">
        <field name="name">partner.omisell.webhook.log.tree</field>
        <field name="model">partner.omisell.webhook.log</field>
        <field name="arch" type="xml">
            <list create="0" delete="0" edit="0">
                <field name="received_at"/>
                <field name="webhook_event"/>
                <field name="http_status"/>
                <field name="result_status"/>
                <field name="order_number"/>
                <field name="order_status_name"/>
                <field name="points_awarded"/>
                <field name="reward_points"/>
                <field name="message"/>
            </list>
        </field>
    </record>

    <record id="action_partner_omisell_webhook_log" model="ir.actions.act_window">
        <field name="name">Omisell Webhook Logs</field>
        <field name="res_model">partner.omisell.webhook.log</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
