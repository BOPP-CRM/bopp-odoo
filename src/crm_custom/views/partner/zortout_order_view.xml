<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_zortout_order_tree" model="ir.ui.view">
        <field name="name">partner.zortout.order.tree</field>
        <field name="model">partner.zortout.order</field>
        <field name="arch" type="xml">
            <list>
                <field name="order_number"/>
                <field name="zortout_order_id"/>
                <field name="customer_name"/>
                <field name="customer_phone"/>
                <field name="amount"/>
                <field name="payment_status"/>
                <field name="order_status"/>
                <field name="points_awarded"/>
                <field name="reward_points"/>
                <field name="last_webhook_at"/>
            </list>
        </field>
    </record>

    <record id="view_partner_zortout_order_form" model="ir.ui.view">
        <field name="name">partner.zortout.order.form</field>
        <field name="model">partner.zortout.order</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id" readonly="1"/>
                            <field name="order_number" readonly="1"/>
                            <field name="zortout_order_id" readonly="1"/>
                            <field name="webhook_method" readonly="1"/>
                            <field name="last_webhook_at" readonly="1"/>
                        </group>
                        <group>
                            <field name="amount" readonly="1"/>
                            <field name="payment_amount" readonly="1"/>
                            <field name="payment_status" readonly="1"/>
                            <field name="order_status" readonly="1"/>
                            <field name="points_awarded" readonly="1"/>
                            <field name="points_awarded_at" readonly="1"/>
                        </group>
                    </group>
                    <group string="Customer">
                        <field name="customer_name" readonly="1"/>
                        <field name="customer_phone" readonly="1"/>
                        <field name="customer_email" readonly="1"/>
                        <field name="user_id" readonly="1"/>
                    </group>
                    <group string="Points">
                        <field name="tier_convert_points" readonly="1"/>
                        <field name="reward_points" readonly="1"/>
                        <field name="spending_point_id" readonly="1"/>
                        <field name="reward_point_id" readonly="1"/>
                        <field name="receipt_redeem_id" readonly="1"/>
                    </group>
                    <group string="Error" invisible="not error_message">
                        <field name="error_message" readonly="1" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_partner_zortout_order" model="ir.actions.act_window">
        <field name="name">Zortout Orders</field>
        <field name="res_model">partner.zortout.order</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
