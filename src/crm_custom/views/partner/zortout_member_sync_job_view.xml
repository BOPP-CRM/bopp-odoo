<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_zortout_member_sync_job_tree" model="ir.ui.view">
        <field name="name">partner.zortout.member.sync.job.tree</field>
        <field name="model">partner.zortout.member.sync.job</field>
        <field name="arch" type="xml">
            <list>
                <field name="create_date"/>
                <field name="partner_id"/>
                <field name="state"/>
                <field name="total"/>
                <field name="processed"/>
                <field name="succeeded"/>
                <field name="failed"/>
                <field name="started_at"/>
                <field name="finished_at"/>
            </list>
        </field>
    </record>

    <record id="view_partner_zortout_member_sync_job_form" model="ir.ui.view">
        <field name="name">partner.zortout.member.sync.job.form</field>
        <field name="model">partner.zortout.member.sync.job</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id" readonly="1"/>
                            <field name="state" readonly="1"/>
                            <field name="current_user_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="total" readonly="1"/>
                            <field name="processed" readonly="1"/>
                            <field name="succeeded" readonly="1"/>
                            <field name="failed" readonly="1"/>
                            <field name="started_at" readonly="1"/>
                            <field name="finished_at" readonly="1"/>
                        </group>
                    </group>
                    <group string="Last Error">
                        <field name="last_error" readonly="1" nolabel="1"/>
                    </group>
                    <field name="pending_user_ids" readonly="1">
                        <list>
                            <field name="display_name"/>
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="zortout_sync_status"/>
                            <field name="zortout_synced_at"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_partner_zortout_member_sync_job" model="ir.actions.act_window">
        <field name="name">Zortout Member Sync Jobs</field>
        <field name="res_model">partner.zortout.member.sync.job</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
